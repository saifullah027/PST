import java.util.*;

public class CyclicDigitSum {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.nextLine();

        int n = s.length();
        int totalSum = 0;

        for (int i = 0; i < n; i++) {
            int cycleSum = 0;
            for (int j = i; j < n; j++) {
                cycleSum += s.charAt(j) - '0';
            }
            totalSum += cycleSum;
        }

        System.out.println(totalSum);
    }
}
